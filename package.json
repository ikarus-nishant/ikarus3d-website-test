{
  "name": "ikarus-3d-website",
  "version": "5.2.7",
  "homepage": "https://github.com/ikarus-nest/ikarus3d/blob/main/README.md",
  "keywords": [
    "website",
    "ikarus3d"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ikarus-nest/ikarus3d"
  },
  "private": true,
  "sideEffects": false,
  "scripts": {
    "build": "npm run build:css && remix build",
    "build:css": "tailwindcss -m -i ./styles/app.css -o app/styles/app.css --minify",
    "local": "cross-env NODE_ENV=development dotenv -e ./config/local/.env concurrently \"npm run dev:css\" \"remix dev\"",
    "dev": "cross-env NODE_ENV=development dotenv -e ./config/dev/.env concurrently \"npm run dev:css\" \"remix dev\"",
    "dev:css": "tailwindcss -w -i ./styles/app.css -o app/styles/app.css --minify"
  },
  "dependencies": {
    "@google/model-viewer": "3.2.1",
    "@headlessui/react": "1.7.4",
